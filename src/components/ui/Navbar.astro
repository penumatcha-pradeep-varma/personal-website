---
const navLinks = [
  { label: 'Home',       href: '/#home',       section: 'home' },
  { label: 'Experience', href: '/#experience', section: 'experience' },
  { label: 'About Me',   href: '/#about',      section: 'about' },
  { label: 'Blogs',      href: '/#blogs',      section: 'blogs' },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center group transition-opacity">
      <span
        class="font-mono font-black text-xl select-none"
        style="letter-spacing: 0.18em; background: linear-gradient(120deg, #00d4ff 0%, #a78bfa 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; filter: drop-shadow(0 0 8px rgba(0,212,255,0.35));"
      >PVP</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              data-nav-section={link.section}
              class="nav-link relative font-sans text-sm font-medium transition-colors duration-200 group text-muted hover:text-light"
            >
              {link.label}
              <span class="nav-underline absolute -bottom-0.5 left-0 h-px bg-primary transition-all duration-300 w-0 group-hover:w-full" />
            </a>
          </li>
        ))
      }

      <!-- Resume — opens PDF in new tab, works on both http and https -->
      <li>
        <a
          href="/Pradeep_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link relative font-sans text-sm font-medium transition-colors duration-200 group text-muted hover:text-light"
        >
          Resume ↗
          <span class="nav-underline absolute -bottom-0.5 left-0 h-px bg-primary transition-all duration-300 w-0 group-hover:w-full" />
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-px bg-light transition-all duration-300 origin-center" id="bar1"></span>
      <span class="block w-6 h-px bg-light transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-px bg-light transition-all duration-300 origin-center" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-dark-border bg-dark-surface/95 backdrop-blur-md px-6 py-6"
  >
    <ul class="flex flex-col gap-5" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              data-nav-section-mobile={link.section}
              class="mobile-nav-link text-base font-medium transition-colors text-muted hover:text-light"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2 border-t border-dark-border">
        <a
          href="/Pradeep_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-mono text-sm font-semibold px-4 py-2 rounded-lg transition-all duration-200"
          style="color: #00d4ff; border: 1px solid rgba(0,212,255,0.3); background: rgba(0,212,255,0.06);"
        >
          View Resume ↗
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  nav.nav-scrolled {
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #1e1e3a;
  }

  .nav-link.is-active {
    color: #00d4ff;
  }

  .nav-link.is-active .nav-underline {
    width: 100%;
  }
</style>

<script>
  // ── Mobile hamburger ──────────────────────────────────────────
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  let open = false;

  btn.addEventListener('click', () => {
    open = !open;
    btn.setAttribute('aria-expanded', String(open));
    menu.classList.toggle('hidden', !open);

    if (open) {
      bar1.style.transform = 'rotate(45deg) translate(3px, 3px)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'rotate(-45deg) translate(3px, -3px)';
    } else {
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    }
  });

  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      menu.classList.add('hidden');
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
      btn.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Active section tracking via ScrollTrigger ─────────────────
  import { ScrollTrigger } from '@/lib/gsap';

  const desktopLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-section]');
  const mobileLinks  = document.querySelectorAll<HTMLAnchorElement>('[data-nav-section-mobile]');

  function setActive(sectionId: string) {
    desktopLinks.forEach((link) => {
      const active = link.dataset.navSection === sectionId;
      link.classList.toggle('is-active', active);
    });
    mobileLinks.forEach((link) => {
      const active = link.dataset.navSectionMobile === sectionId;
      link.classList.toggle('text-primary', active);
      link.classList.toggle('text-muted', !active);
    });
  }

  setActive('home');

  const sections = ['home', 'experience', 'about', 'blogs'];

  sections.forEach((id) => {
    const el = document.getElementById(id);
    if (!el) return;

    ScrollTrigger.create({
      trigger: el,
      start: 'top 45%',
      onEnter:     () => setActive(id),
      onEnterBack: () => setActive(id),
    });
  });
</script>
