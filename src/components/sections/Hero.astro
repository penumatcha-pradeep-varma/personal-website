---
---

<section
  id="home"
  class="relative w-full h-screen overflow-hidden flex items-center"
>
  <!-- ── Full-bleed background image ────────────────────────────── -->
  <div class="absolute inset-0">
    <img
      id="hero-photo"
      src="/images/IMG_9905.PNG"
      alt="Pradeep Varma Penumatcha"
      class="absolute inset-0 w-full h-full object-cover will-change-transform select-none"
      style="object-position: center top; transform: scale(1.06);"
      loading="eager"
      draggable="false"
    />
  </div>

  <!-- ── Gradient overlays ───────────────────────────────────────── -->
  <!-- Left dark wash for text readability -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(105deg, rgba(10,10,15,0.95) 0%, rgba(10,10,15,0.78) 35%, rgba(10,10,15,0.25) 62%, transparent 100%)"
  ></div>
  <!-- Bottom merge with page -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(10,10,15,0.45) 0%, transparent 18%, transparent 55%, rgba(10,10,15,0.88) 88%, #0a0a0f 100%)"
  ></div>
  <!-- Top navbar space -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(10,10,15,0.65) 0%, transparent 14%)"
  ></div>

  <!-- ── Floating particles ──────────────────────────────────────── -->
  <canvas
    id="hero-particles"
    class="absolute inset-0 w-full h-full pointer-events-none"
    aria-hidden="true"
    style="opacity: 0.35"
  ></canvas>

  <!-- ── Left: text content ─────────────────────────────────────── -->
  <div
    id="hero-content"
    class="relative z-10 px-8 md:px-14 lg:px-20 max-w-2xl"
  >
    <!-- Eyebrow -->
    <div id="hero-label" class="flex items-center gap-3 mb-6">
      <div class="w-8 h-px bg-primary flex-shrink-0"></div>
      <p class="section-label">AI Data Engineer · 11+ Years · JPMorgan Chase</p>
    </div>

    <!-- Name -->
    <h1
      id="hero-name"
      class="font-display font-bold text-5xl sm:text-6xl md:text-7xl text-light leading-[1.05] mb-5"
    >
      Pradeep<br />
      Varma<br />
      <span class="text-gradient">Penumatcha</span>
    </h1>

    <!-- Descriptor -->
    <p id="hero-sub" class="text-muted text-base md:text-lg leading-relaxed mb-5 max-w-md">
      Building AI-ready data platforms that process<br class="hidden md:block" />
      terabytes daily — AWS · Spark · Databricks · Kafka
    </p>

    <!-- Tech badges -->
    <div id="hero-badges" class="flex flex-wrap gap-2 mb-8">
      {
        ['PySpark', 'AWS EMR', 'Delta Lake', 'Kafka', 'Terraform', 'Airflow'].map((t) => (
          <span class="font-mono text-xs text-primary/75 border border-primary/20 px-2.5 py-1 rounded bg-primary/5">
            {t}
          </span>
        ))
      }
    </div>

    <!-- CTAs -->
    <div id="hero-cta" class="flex flex-wrap gap-4">
      <a href="#experience" class="btn-primary">View Experience</a>
      <a
        href="/Pradeep_Resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline"
      >
        Download Resume ↗
      </a>
    </div>
  </div>

  <!-- ── Scroll indicator ────────────────────────────────────────── -->
  <div
    id="hero-scroll"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
  >
    <span class="font-mono text-xs tracking-widest uppercase text-muted/40">Scroll</span>
    <div class="scroll-line w-px h-12 bg-gradient-to-b from-primary/50 to-transparent"></div>
  </div>
</section>

<style>
  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.5; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(0.85); }
  }
.scroll-line {
    animation: scroll-pulse 2s ease-in-out infinite;
    transform-origin: top;
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '@/lib/gsap';

  // ── Particle canvas ────────────────────────────────────────────
  const canvas = document.getElementById('hero-particles') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    interface Particle { x: number; y: number; vx: number; vy: number; r: number; a: number }
    const particles: Particle[] = [];
    let rafId = 0;

    const resize = () => {
      canvas.width  = canvas.clientWidth;
      canvas.height = canvas.clientHeight;
    };
    resize();
    window.addEventListener('resize', resize, { passive: true });

    for (let i = 0; i < 60; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.28,
        vy: (Math.random() - 0.5) * 0.28,
        r: Math.random() * 1.3 + 0.3,
        a: Math.random() * 0.28 + 0.06,
      });
    }

    const draw = () => {
      rafId = requestAnimationFrame(draw);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (const p of particles) {
        p.x = (p.x + p.vx + canvas.width)  % canvas.width;
        p.y = (p.y + p.vy + canvas.height) % canvas.height;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(0,212,255,${p.a})`;
        ctx.fill();
      }
    };
    draw();

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
      window.removeEventListener('resize', resize);
    });
  }

  // Prevent browser scroll-restore from fighting the entrance animations
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  window.scrollTo(0, 0);

  // ── Set initial positions (hidden) ─────────────────────────────
  gsap.set('#hero-label',  { opacity: 0, x: -30 });
  gsap.set(['#hero-name', '#hero-sub', '#hero-badges', '#hero-cta'], { opacity: 0, y: 22 });
  gsap.set('#hero-scroll', { opacity: 0 });
  gsap.set('.stat-card',   { opacity: 0, x: 24 });

  // ── Image zoom-out on load ─────────────────────────────────────
  gsap.to('#hero-photo', { scale: 1, duration: 2.2, ease: 'power2.out', delay: 0.1 });

  // ── Stat cards slide in after entrance ────────────────────────
  gsap.to('.stat-card', { opacity: 1, x: 0, duration: 0.9, stagger: 0.15, ease: 'power3.out', delay: 1.1 });

  // ── Parallax: photo drifts on scroll ──────────────────────────
  gsap.to('#hero-photo', {
    y: '14%',
    ease: 'none',
    scrollTrigger: { trigger: '#home', start: 'top top', end: 'bottom top', scrub: 0.8, immediateRender: false },
  });

  // ── Content lifts/fades on scroll ─────────────────────────────
  gsap.to('#hero-content', {
    y: '-8%', opacity: 0, ease: 'none',
    scrollTrigger: { trigger: '#home', start: 'top top', end: '50% top', scrub: 0.5, immediateRender: false },
  });

  // ── Stat cards fade on scroll ──────────────────────────────────
  gsap.to('#hero-stat-cards', {
    opacity: 0, y: 20, ease: 'none',
    scrollTrigger: { trigger: '#home', start: '20% top', end: '60% top', scrub: 0.5, immediateRender: false },
  });

  // ── Entrance stagger (clean gsap.to — no from/to conflicts) ───
  const tl = gsap.timeline({ delay: 0.25 });
  tl.to('#hero-label',  { x: 0,  opacity: 1, duration: 0.65, ease: 'power3.out' })
    .to('#hero-name',   { y: 0,  opacity: 1, duration: 0.85, ease: 'power3.out' }, '-=0.4')
    .to('#hero-sub',    { y: 0,  opacity: 1, duration: 0.55, ease: 'power3.out' }, '-=0.5')
    .to('#hero-badges', { y: 0,  opacity: 1, duration: 0.5,  ease: 'power3.out' }, '-=0.35')
    .to('#hero-cta',    { y: 0,  opacity: 1, duration: 0.5,  ease: 'power3.out' }, '-=0.3')
    .to('#hero-scroll', { opacity: 1, duration: 0.6 }, '-=0.1');
</script>
