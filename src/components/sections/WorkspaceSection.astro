---
const techStack = [
  { label: 'Databricks',    color: '#ff6b35' },
  { label: 'LLM / AI',      color: '#00d4ff' },
  { label: 'SRE Monitor',   color: '#00ff88' },
  { label: 'RAG · Vector',  color: '#7c3aed' },
  { label: 'MCP · Agents',  color: '#f59e0b' },
  { label: 'Apache Kafka',  color: '#ef4444' },
];
---

<section
  id="workspace-section"
  class="relative w-full overflow-hidden"
  style="height: 100vh; min-height: 640px;"
>
  <!-- Top gradient: merge from previous section -->
  <div
    class="absolute top-0 left-0 right-0 h-24 pointer-events-none z-10"
    style="background: linear-gradient(to bottom, #0a0a0f, transparent)"
  ></div>

  <!-- Three.js canvas -->
  <canvas
    id="workspace-canvas"
    class="absolute inset-0 w-full h-full"
    aria-label="Interactive 3D workspace animation showing data engineering ecosystem"
  ></canvas>

  <!-- Scene overlay gradient (edges) -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 55%, rgba(10,10,15,0.6) 100%)"
  ></div>

  <!-- Bottom content overlay -->
  <div class="absolute bottom-0 left-0 right-0 z-20">
    <!-- Fade up from bottom -->
    <div
      class="pointer-events-none"
      style="background: linear-gradient(to top, #0a0a0f 0%, rgba(10,10,15,0.8) 40%, transparent 100%); height: 180px;"
    ></div>

    <!-- Section label + tech chips -->
    <div class="bg-dark pb-10 px-6">
      <div class="max-w-5xl mx-auto text-center" id="workspace-labels">
        <p class="section-label mb-4">The Ecosystem I Build In</p>
        <div class="flex flex-wrap justify-center gap-3">
          {
            techStack.map((t) => (
              <span
                class="inline-flex items-center gap-2 font-mono text-xs px-4 py-1.5 rounded-full border"
                style={`color: ${t.color}; border-color: ${t.color}33; background: ${t.color}0d`}
              >
                <span
                  class="w-1.5 h-1.5 rounded-full animate-pulse-slow"
                  style={`background: ${t.color}`}
                ></span>
                {t.label}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll-triggered reveal label (top center, appears on scroll) -->
  <div
    id="workspace-heading"
    class="absolute top-16 left-0 right-0 z-20 text-center opacity-0 pointer-events-none"
  >
    <p class="section-label mb-2">Work Environment</p>
    <h2 class="font-display font-bold text-3xl md:text-4xl text-light">
      AI Data Engineer<span class="text-primary"> · </span>in Action
    </h2>
  </div>
</section>

<script>
  import { WorkspaceScene } from '@/components/three/WorkspaceScene';
  import { gsap, ScrollTrigger } from '@/lib/gsap';

  const canvas = document.getElementById('workspace-canvas') as HTMLCanvasElement;
  let scene: WorkspaceScene | null = null;

  // Lazy-init: only create Three.js scene when section enters viewport
  // (saves resources — not loaded until user scrolls to it)
  ScrollTrigger.create({
    trigger: '#workspace-section',
    start: 'top 85%',
    once: true,
    onEnter: () => {
      scene = new WorkspaceScene(canvas);
    },
  });

  // Heading reveal on scroll
  gsap.to('#workspace-heading', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#workspace-section',
      start: 'top 70%',
    },
  });

  // Tech label chips stagger in
  gsap.from('#workspace-labels', {
    y: 20,
    opacity: 0,
    duration: 0.7,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#workspace-section',
      start: 'bottom 90%',
    },
  });

  // Dispose on page navigation
  document.addEventListener('astro:before-swap', () => {
    scene?.dispose();
    scene = null;
  });
</script>
