---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { skillGroups } from '@/data/index';

const experiences = [
  {
    company: 'JPMorgan Chase & Co.',
    role: 'Senior Data Engineer (SSE III)',
    period: 'Sep 2021 – Present',
    location: 'Hyderabad, India',
    domain: 'Banking',
    current: true,
    bullets: [
      'Operating as AI Data Engineer — building Databricks Pipelines for LLM/GenAI feature stores and AI-driven analytical workloads, bridging data engineering with enterprise AI initiatives.',
      'Architected PySpark ETL/ELT pipelines on AWS EMR processing multi-TB daily datasets for analytics and ML feature stores.',
      'Tuned Spark jobs via partitioning, broadcast joins, and shuffle reduction — cutting runtimes and AWS compute costs significantly.',
      'Built Databricks workloads with Delta Lake medallion (bronze/silver/gold) architecture for versioned, auditable data layers supporting AI/ML model training.',
      'Provisioned AWS infrastructure using Terraform (HashiCorp Certified), enabling repeatable IaC deployments across dev/staging/prod.',
      'Orchestrated workflows with Apache Airflow and Control-M; integrated S3, RDBMS, and REST APIs with data quality validation.',
    ],
    tags: ['AI Data Eng', 'PySpark', 'AWS EMR', 'Databricks', 'Delta Lake', 'Terraform', 'Airflow', 'LLM/GenAI'],
  },
  {
    company: 'BA Continuum – Bank of America',
    role: 'Data Engineer (Apps Analyst II)',
    period: 'Jul 2019 – Sep 2021',
    location: 'Hyderabad, India',
    domain: 'Banking',
    current: false,
    bullets: [
      'Migrated Oracle/SQL Server data to Hadoop/Spark via Apache Sqoop for banking regulatory analytics at scale.',
      'Built Spark Scala curated datasets; designed dimensional models (star schema, SCD Type 1 & 2) in Hive and Spark SQL.',
      'Integrated Apache Kafka for near-real-time ingestion; tuned Hive/Spark SQL queries for reporting performance improvements.',
    ],
    tags: ['Spark Scala', 'Hadoop', 'Apache Kafka', 'Hive', 'Sqoop', 'SQL Server', 'Oracle'],
  },
  {
    company: 'Tech Mahindra Pvt Ltd',
    role: 'Senior Software Engineer',
    period: 'Aug 2018 – Jul 2019',
    location: 'Hyderabad, India',
    domain: 'Telecom',
    current: false,
    bullets: [
      'Built Kafka + Spark Streaming real-time pipelines for telecom network analytics; stored events in Apache Cassandra for low-latency dashboards.',
      'Delivered sub-second latency insights for network operations teams supporting SLA monitoring and fault detection.',
    ],
    tags: ['Kafka', 'Spark Streaming', 'Cassandra', 'Python', 'Real-Time'],
  },
  {
    company: 'Cognizant Technology Solutions',
    role: 'Big Data Engineer (Analyst)',
    period: 'May 2014 – Jul 2018',
    location: 'Hyderabad, India',
    domain: 'IT Services',
    current: false,
    bullets: [
      'Developed batch pipelines using Sqoop, Hive, and Spark Scala; Kafka + Flume real-time ingestion.',
      'Data stored in ORC/Parquet formats for downstream BI and reporting workloads.',
    ],
    tags: ['Sqoop', 'Hive', 'Spark Scala', 'Kafka', 'Flume', 'ORC', 'Parquet'],
  },
];

const certifications = [
  {
    name: 'HashiCorp Certified: Terraform Associate',
    org: 'HashiCorp',
    detail: 'IaC for cloud-agnostic deployments (AWS · Azure · GCP)',
    color: 'primary',
  },
  {
    name: 'Databricks Hands-On Certification',
    org: 'Databricks',
    detail: 'Delta Lake · Spark Tuning · Databricks Jobs · Unity Catalog · Notebooks',
    color: 'accent',
  },
];

---

<BaseLayout
  title="Experience"
  description="11+ years of enterprise data engineering at JPMorgan Chase, Bank of America, Tech Mahindra, and Cognizant."
>
  <main class="min-h-screen pt-28 pb-20 px-6 max-w-5xl mx-auto">
    <!-- Page header -->
    <div class="mb-14" data-speed="0.95">
      <p class="section-label mb-3">Career Journey</p>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5">
        <h1 class="section-title text-4xl md:text-5xl">Experience</h1>
        <a
          href="/Pradeep_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary self-start"
        >
          Download Resume ↗
        </a>
      </div>
      <div class="glow-line mt-6"></div>
    </div>

    <!-- Timeline -->
    <div class="relative pl-8 border-l border-dark-border space-y-14 mb-20">
      {
        experiences.map((exp, i) => (
          <div class="relative" data-exp>
            <!-- Timeline dot -->
            <div
              class:list={[
                'timeline-dot',
                exp.current ? 'bg-primary shadow-[0_0_14px_#00d4ff]' : 'bg-dark-border',
              ]}
            />

            <div class="card p-7 hover:border-primary/25 transition-colors duration-300">
              <!-- Company + badge -->
              <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <h2 class="font-display font-semibold text-xl text-light">{exp.company}</h2>
                    {exp.current && (
                      <span class="inline-flex items-center px-2 py-0.5 bg-primary/15 border border-primary/30 text-primary text-xs font-mono rounded-full">
                        Current
                      </span>
                    )}
                  </div>
                  <p class="text-primary font-medium">{exp.role}</p>
                </div>
                <div class="text-right">
                  <p class="font-mono text-sm text-muted">{exp.period}</p>
                  <p class="text-xs text-muted/60 mt-0.5">{exp.location}</p>
                </div>
              </div>

              <!-- Bullets -->
              <ul class="space-y-2.5 mb-6">
                {exp.bullets.map((b) => (
                  <li class="flex gap-3 text-muted text-sm leading-relaxed">
                    <span class="text-primary mt-0.5 shrink-0">▸</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2">
                {exp.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Certifications -->
    <section class="mb-20">
      <p class="section-label mb-3">Credentials</p>
      <h2 class="section-title text-2xl md:text-3xl mb-8">Certifications</h2>

      <div class="grid md:grid-cols-2 gap-5">
        {
          certifications.map((cert) => (
            <div class="card p-6 border-l-2 border-l-primary">
              <p class="font-display font-semibold text-light mb-1">{cert.name}</p>
              <p class="text-primary text-sm font-mono mb-2">{cert.org}</p>
              <p class="text-muted text-xs">{cert.detail}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Skills grid -->
    <section>
      <p class="section-label mb-3">Technical Stack</p>
      <h2 class="section-title text-2xl md:text-3xl mb-8">Core Skills</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          skillGroups.map((group) => (
            <div class="card p-5" data-skill-group>
              <p class="font-mono text-xs text-primary uppercase tracking-wider mb-3">{group.label}</p>
              <div class="flex flex-wrap gap-1.5">
                {group.skills.map((skill) => (
                  <span class="tag text-xs">{skill}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  import { gsap, ScrollTrigger } from '@/lib/gsap';

  gsap.from('[data-exp]', {
    x: -30,
    opacity: 0,
    duration: 0.7,
    stagger: 0.15,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '[data-exp]',
      start: 'top 85%',
    },
  });

  gsap.from('[data-skill-group]', {
    y: 25,
    opacity: 0,
    duration: 0.5,
    stagger: 0.08,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '[data-skill-group]',
      start: 'top 85%',
    },
  });
</script>
